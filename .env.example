# Copy this file to ".env" and fill in your keys. See SETUP.md for how to get each.
# The workshop uses a real AI-engineering stack, so ALL of the keys below are
# required (the notebooks fail fast if any are missing).

# ============================================================================
# 1. OpenAI (the brain) -- https://platform.openai.com/api-keys
# ============================================================================
OPENAI_API_KEY=sk-your-key-here

# Optional: point at any OpenAI-compatible endpoint (Azure, local vLLM/Ollama,
# a corporate proxy, etc.). Leave unset to use the default OpenAI endpoint.
# OPENAI_BASE_URL=https://api.openai.com/v1

# Default model for the whole workshop. Cheap + fast. Swap freely.
WORKSHOP_MODEL=gpt-4o-mini

# ============================================================================
# 2. Langfuse (observability / tracing) -- https://cloud.langfuse.com  (free)
#    Create a project, then Settings -> API Keys.
# ============================================================================
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
# Pick the region that matches your Langfuse account:
#   US: https://us.cloud.langfuse.com      EU: https://cloud.langfuse.com
LANGFUSE_BASE_URL=https://us.cloud.langfuse.com

# ============================================================================
# 3. Weights & Biases (experiment tracking) -- https://wandb.ai/authorize
# ============================================================================
WANDB_API_KEY=...

# ============================================================================
# 4. Qdrant Cloud (vector DB) -- https://cloud.qdrant.io  (free 1GB cluster)
#    Create a cluster, copy its URL, then generate an API key.
# ============================================================================
QDRANT_URL=https://YOUR-CLUSTER-ID.cloud.qdrant.io:6333
QDRANT_API_KEY=...
